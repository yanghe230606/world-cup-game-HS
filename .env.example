# Debug Mode
# Set VITE_DEBUG=true to enable physics debug outlines and entity creation logs.
# These are automatically enabled in development mode (npm run dev).
VITE_DEBUG=false

# Database (Postgres) — required only if the app uses the DB layer in src/db
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vibe_game_2d_template

# Happy Seeds（PROJECT_ID → next.config env PROJECT_ID）
HAPPYSEEDS_PROJECT_ID=

# Reactus API 根地址（仅 scheme + host，不含路径）
REACTUS_BASE_URL=https://dev-reactus-api.happyseeds.ai

# Umami Analytics
NEXT_PUBLIC_UMAMI_SCRIPT_URL="https://your-umami-domain/script.js"
NEXT_PUBLIC_UMAMI_WEBSITE_ID="your-website-id"